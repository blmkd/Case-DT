<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Contact_must_be_in_Account_ZIP_Code</fullName>
    <active>false</active>
    <errorConditionFormula>AND(NOT(ISBLANK(AccountId)),MailingPostalCode  &lt;&gt; Account.ShippingPostalCode)</errorConditionFormula>
    <errorMessage>Error when creating or updating: Please check if the contact is already used or if the email and shipping zip codes</errorMessage>
</ValidationRule>
